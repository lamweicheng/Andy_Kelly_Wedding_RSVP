generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum EventCity {
  SAN_FRANCISCO
  MALAYSIA
  HONG_KONG
}

enum AttendanceType {
  IN_PERSON
  VIRTUAL
  DECLINED
}

model Guest {
  id             String         @id @default(cuid())
  firstName      String
  lastName       String
  email          String         @unique
  phone          String?
  attendanceType AttendanceType @default(IN_PERSON)
  selectedCities EventCity[]
  guestCount     Int            @default(1)
  notes          String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([attendanceType])
}

model EventDetail {
  id                  String    @id @default(cuid())
  city                EventCity @unique
  title               String
  eventDate           DateTime
  venueLabel          String?
  venueName           String?
  address             String?
  secondaryVenueLabel String?
  secondaryVenueName  String?
  secondaryAddress    String?
  venueStatus         String?
  description         String?
  zoomLink            String?
  latitude            Float?
  longitude           Float?
  timeline            Json?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}