generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum EventCity {
  SAN_FRANCISCO
  MALAYSIA
  HONG_KONG
}

enum RSVPStatus {
  PENDING
  ATTENDING
  NOT_ATTENDING
  VIRTUAL
}

model Guest {
  id          String     @id @default(cuid())
  firstName   String
  lastName    String
  email       String     @unique
  phone       String?
  city        EventCity?
  status      RSVPStatus @default(PENDING)
  guestCount  Int        @default(1)
  notes       String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([city, status])
}

model EventDetail {
  id          String    @id @default(cuid())
  city        EventCity @unique
  title       String
  eventDate   DateTime
  venueName   String?
  address     String?
  description String?
  isVirtual   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}